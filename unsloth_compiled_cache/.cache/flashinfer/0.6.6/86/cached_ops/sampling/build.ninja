ninja_required_version = 1.3
name = sampling
cuda_home = /usr
cxx = c++
nvcc = $cuda_home/bin/nvcc

common_cflags = -DPy_LIMITED_API=0x03090000 $
    -D_GLIBCXX_USE_CXX11_ABI=1 $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/include/python3.10 $
    -isystem $cuda_home/include/cccl $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/tvm_ffi/include $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/tvm_ffi/include $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/include $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/csrc $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/cutlass/include $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/cutlass/tools/util/include $
    -isystem /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/spdlog/include
cflags = $common_cflags $
    -fPIC $
    -std=c++17 $
    -Wno-switch-bool $
    -O3
post_cflags =
cuda_cflags = $common_cflags $
    --compiler-options=-fPIC $
    --expt-relaxed-constexpr $
    -gencode=arch=compute_86,code=sm_86 $
    -DFLASHINFER_ENABLE_FP8_E8M0 $
    -DFLASHINFER_ENABLE_FP4_E2M1 $
    -std=c++17 $
    --threads=1 $
    -use_fast_math $
    -DFLASHINFER_ENABLE_F16 $
    -DFLASHINFER_ENABLE_BF16 $
    -DFLASHINFER_ENABLE_FP8_E4M3 $
    -DFLASHINFER_ENABLE_FP8_E5M2 $
    -DNDEBUG $
    -O3
cuda_post_cflags =
ldflags = -shared $
    -L$cuda_home/lib64 $
    -L$cuda_home/lib64/stubs $
    -lcudart $
    -lcuda

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags
  depfile = $out.d
  deps = gcc

rule link
  command = $cxx $in $ldflags -o $out

build /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/sampling.cuda.o: cuda_compile /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/csrc/sampling.cu
build /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/renorm.cuda.o: cuda_compile /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/csrc/renorm.cu
build /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/flashinfer_sampling_binding.cuda.o: cuda_compile /home/chufeng/SoftwareInstalled/anaconda3/envs/LLM/lib/python3.10/site-packages/flashinfer/data/csrc/flashinfer_sampling_binding.cu

build /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/sampling.so: link /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/sampling.cuda.o /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/renorm.cuda.o /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/flashinfer_sampling_binding.cuda.o
default /home/chufeng/Desktop/LLM RL/unsloth_compiled_cache/.cache/flashinfer/0.6.6/86/cached_ops/sampling/sampling.so
